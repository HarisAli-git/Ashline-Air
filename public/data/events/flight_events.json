[
  {
    "id": "engine_overheating",
    "title": "Engine Overheating",
    "description": "Warning lights flash on the instrument panel. Engine temperature is climbing into the red.",
    "trigger": "on_engine_temp_high",
    "triggerThreshold": 0.85,
    "probability": 0.8,
    "cooldownSeconds": 120,
    "tags": ["engine", "critical"],
    "choices": [
      {
        "id": "reduce_throttle",
        "label": "Reduce throttle to cool down",
        "consequences": [
          { "type": "delta", "target": "throttle", "value": -0.3, "description": "Throttle reduced" },
          { "type": "delta", "target": "engineTemp", "value": -0.2, "description": "Engine begins cooling" }
        ]
      },
      {
        "id": "push_through",
        "label": "Push through — stay on schedule",
        "consequences": [
          { "type": "delta", "target": "engineTemp", "value": 0.15, "description": "Engine temp spikes further" },
          { "type": "delta", "target": "integrity", "value": -8, "description": "Engine stress damages airframe" }
        ]
      },
      {
        "id": "emergency_coolant",
        "label": "Dump emergency coolant",
        "consequences": [
          { "type": "set", "target": "engineTemp", "value": 0.4, "description": "Engine temp drops sharply" },
          { "type": "delta", "target": "integrity", "value": -2, "description": "Minor coolant system stress" }
        ]
      }
    ]
  },
  {
    "id": "fuel_leak",
    "title": "Fuel Leak Detected",
    "description": "The fuel gauge is dropping faster than expected. You spot a thin mist trailing from the wing.",
    "trigger": "on_fuel_low",
    "triggerThreshold": 0.4,
    "probability": 0.3,
    "cooldownSeconds": 999,
    "tags": ["fuel", "critical"],
    "choices": [
      {
        "id": "seal_leak",
        "label": "Attempt to seal the leak manually",
        "consequences": [
          { "type": "multiply", "target": "fuelBurnRate", "value": 1.3, "description": "Leak partially sealed — reduced but not stopped" },
          { "type": "delta", "target": "integrity", "value": -3, "description": "Slight structural stress from repair attempt" }
        ]
      },
      {
        "id": "divert_immediately",
        "label": "Divert to nearest settlement",
        "consequences": [
          { "type": "multiply", "target": "fuelBurnRate", "value": 1.6, "description": "Leak worsens as you descend" }
        ]
      }
    ]
  },
  {
    "id": "bird_strike",
    "title": "Bird Strike",
    "description": "A flock of large birds appears from nowhere. A dull thud shakes the cockpit.",
    "trigger": "random",
    "probability": 0.04,
    "cooldownSeconds": 300,
    "tags": ["random", "damage"],
    "choices": [
      {
        "id": "assess_damage",
        "label": "Assess damage and continue",
        "consequences": [
          { "type": "delta", "target": "integrity", "value": -10, "description": "Bird strike damages leading edge" },
          { "type": "delta", "target": "engineTemp", "value": 0.1, "description": "Debris ingested into engine" }
        ]
      },
      {
        "id": "emergency_land",
        "label": "Declare emergency and land immediately",
        "consequences": [
          { "type": "delta", "target": "integrity", "value": -5, "description": "You manage a controlled descent" }
        ]
      }
    ]
  },
  {
    "id": "dust_storm_approach",
    "title": "Dust Storm on the Horizon",
    "description": "A wall of orange haze fills the windscreen. A major dust storm is sweeping across your route.",
    "trigger": "on_weather_change",
    "probability": 0.7,
    "cooldownSeconds": 600,
    "tags": ["weather", "navigation"],
    "choices": [
      {
        "id": "fly_through",
        "label": "Fly through — you've seen worse",
        "consequences": [
          { "type": "delta", "target": "integrity", "value": -15, "description": "Abrasive particles scour the airframe" },
          { "type": "multiply", "target": "fuelBurnRate", "value": 1.2, "description": "Headwinds increase fuel burn" }
        ]
      },
      {
        "id": "climb_over",
        "label": "Climb above the storm",
        "consequences": [
          { "type": "delta", "target": "fuel", "value": -20, "description": "Climb burns extra fuel" },
          { "type": "delta", "target": "integrity", "value": -3, "description": "Minor turbulence at altitude" }
        ]
      },
      {
        "id": "go_around",
        "label": "Detour around the storm",
        "consequences": [
          { "type": "delta", "target": "fuel", "value": -30, "description": "Extra distance costs fuel" },
          { "type": "delta", "target": "elapsedSeconds", "value": 600, "description": "Significant time added to flight" }
        ]
      }
    ]
  },
  {
    "id": "distress_signal",
    "title": "Distress Signal",
    "description": "Your radio crackles with a weak distress call. Someone is stranded not far from your current position.",
    "trigger": "random",
    "probability": 0.02,
    "cooldownSeconds": 900,
    "tags": ["random", "reputation"],
    "choices": [
      {
        "id": "investigate",
        "label": "Divert and investigate",
        "consequences": [
          { "type": "delta", "target": "fuel", "value": -25, "description": "Diversion burns fuel" },
          { "type": "add_reputation", "target": "republic", "value": 20, "description": "Republic hears of your rescue" },
          { "type": "add_money", "target": "player", "value": 500, "description": "Reward from survivors" }
        ]
      },
      {
        "id": "ignore",
        "label": "Log the signal and continue",
        "consequences": [
          { "type": "add_reputation", "target": "republic", "value": -10, "description": "Republic pilots talk" }
        ]
      }
    ]
  },
  {
    "id": "strong_headwind",
    "title": "Strong Headwinds",
    "description": "You're fighting a brutal headwind. Ground speed has dropped significantly.",
    "trigger": "on_speed_low",
    "triggerThreshold": 0.5,
    "probability": 0.5,
    "cooldownSeconds": 240,
    "tags": ["weather"],
    "choices": [
      {
        "id": "increase_throttle",
        "label": "Increase throttle to compensate",
        "consequences": [
          { "type": "multiply", "target": "fuelBurnRate", "value": 1.4, "description": "Higher throttle burns more fuel" },
          { "type": "delta", "target": "engineTemp", "value": 0.1, "description": "Engine runs hotter" }
        ]
      },
      {
        "id": "descend_for_calmer_air",
        "label": "Descend to find calmer air",
        "consequences": [
          { "type": "delta", "target": "altitude", "value": -800, "description": "You drop to a lower layer" }
        ]
      }
    ]
  }
]
